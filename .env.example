# KimiClaw Environment Configuration
# Kopiere diese Datei zu .env und trage deine echten API Keys ein

# ============================================================
# REQUIRED: API Keys
# ============================================================

# OpenAI/Kimi API Key (required)
OPENAI_API_KEY=sk-dein-api-key-hier
OPENAI_API_BASE=https://api.moonshot.cn/v1

# Optional: Separate API für Evaluation (kann gleich sein)
EVALUATION_API_KEY=sk-dein-api-key-hier
EVALUATION_API_BASE=https://api.moonshot.cn/v1

# Optional: Web Search API (Tavily)
WEB_SEARCH_API_KEY=tvly-dein-key

# Optional: Code Sandbox (E2B)
E2B_API_KEY=e2b-dein-key
CODE_SANDBOX_PROVIDER=e2b

# ============================================================
# SYSTEM SETTINGS
# ============================================================

# Docker: Disable simulation mode (force real API calls)
DISABLE_SIMULATION=true

# ============================================================
# DEPLOYMENT CONFIGURATION
# ============================================================

# Deployment Mode
# Options: local, docker, streamlit-cloud
DEPLOYMENT_MODE=streamlit-cloud

# Domain (for reference)
DOMAIN=openklaw.streamlit.app

# ============================================================
# DEPLOYMENT NOTES:
# STREAMLIT CLOUD:
#   - HTTPS automatically provided
#   - SSL managed by Streamlit
#   - Deploy via: https://share.streamlit.io
#
# DOCKER (Self-Hosted):
#   - Use: docker-compose -f docker-compose.https.yml up -d
#   - Automatic SSL via Let's Encrypt
#   - Full control over environment
# ============================================================
