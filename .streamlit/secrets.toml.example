# Streamlit Secrets Configuration
# Copy this file to secrets.toml (DO NOT COMMIT!)
# 
# For Streamlit Cloud:
# Add these secrets in your Streamlit Cloud dashboard:
# App → Settings → Secrets

[secrets]
# Required API Keys
OPENAI_API_KEY = "sk-your-openai-api-key-here"
OPENAI_API_BASE = "https://api.moonshot.cn/v1"

# Optional: Separate evaluation API
EVALUATION_API_KEY = "sk-your-evaluation-key-here"
EVALUATION_API_BASE = "https://api.moonshot.cn/v1"

# Optional: Web Search API (Tavily)
WEB_SEARCH_API_KEY = "tvly-your-tavily-key-here"

# Optional: Code Sandbox (E2B)
E2B_API_KEY = "e2b-your-e2b-key-here"
CODE_SANDBOX_PROVIDER = "e2b"

# System Settings
DISABLE_SIMULATION = "true"

# ============================================================
# IMPORTANT: Never commit secrets.toml with real keys!
# Add to .gitignore:
# .streamlit/secrets.toml
# ============================================================
